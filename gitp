#!/bin/bash

# Ultra-quick git script - gitp (no extension for speed)
# Usage: ./gitp ["commit message"]

# Generate default commit message with timestamp
DEFAULT_MSG="changes made on $(date '+%Y-%m-%d | %H:%M:%S')"

# Use provided message or default
COMMIT_MSG="${1:-$DEFAULT_MSG}"

echo "🚀 Quick git commit: $COMMIT_MSG"

# Add, commit, pull --rebase (to sync), then push
BRANCH=$(git branch --show-current)
git add . && \
git commit -m "$COMMIT_MSG" && \
git pull --rebase origin "$BRANCH" 2>/dev/null || true && \
git push origin "$BRANCH"

echo "✅ Done!"
